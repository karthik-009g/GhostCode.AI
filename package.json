{
  "name": "ghost-code",
  "version": "0.1.0",
  "private": true,

  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",

    "lint": "next lint",
    "lint:fix": "next lint --fix",

    "type-check": "tsc --noEmit",

    "format": "prettier --write .",
    "format:check": "prettier --check .",

    "check": "npm run lint && npm run type-check",

    "clean": "rimraf .next",

    "prepare": "husky"
  },

  "dependencies": {
    "next": "14.2.5",

    "react": "^18.3.1",
    "react-dom": "^18.3.1",

    "three": "^0.180.0",
    "animejs": "^4.2.2",
    "three-stdlib": "^2.36.0",

    "@react-three/fiber": "^8.17.10",
    "@react-three/drei": "^9.122.0",
    "@react-three/postprocessing": "^2.19.0",

    "postprocessing": "^6.39.1",

    "motion": "^11.18.2",
    "framer-motion": "^11.18.2",

    "lenis": "^1.3.8",

    "zustand": "^4.5.5",

    "leva": "^0.9.36",

    "react-use-measure": "^2.1.7",

    "suspend-react": "^0.1.3",

    "maath": "^0.10.8",

    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.2"
  },

  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.180.0",

    "typescript": "^5.5.4",

    "tailwindcss": "^3.4.7",
    "postcss": "^8.4.40",
    "autoprefixer": "^10.4.19",

    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "@typescript-eslint/eslint-plugin": "^7.17.0",
    "@typescript-eslint/parser": "^7.17.0",

    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",

    "lint-staged": "^15.2.7",

    "husky": "^9.1.4",

    "rimraf": "^6.0.1"
  },

  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
